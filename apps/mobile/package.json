{
  "name": "well-within-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "test": "jest --runInBand",
    "doctor": "expo-doctor",
    "config:check": "expo config --type public",
    "preflight:release": "npm run config:check",
    "preflight:release:with-doctor": "npm run config:check && npm run doctor",
    "build:ios:testflight": "eas build --platform ios --profile production --non-interactive",
    "build:ios:testflight:skip-fingerprint": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas build --platform ios --profile production --non-interactive",
    "submit:ios:production": "eas submit --platform ios --profile production --latest --non-interactive",
    "release:testflight": "npm run preflight:release && npm run build:ios:testflight && npm run submit:ios:production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@supabase/supabase-js": "^2.47.0",
    "core-rules-engine": "*",
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-linking": "~8.0.11",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.6",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.4",
    "merge-options": "^3.0.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "whatwg-url-without-unicode": "^8.0.0-3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/plugin-transform-classes": "^7.28.6",
    "@react-native/babel-preset": "^0.81.5",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.10",
    "cross-env": "^7.0.3",
    "eas-cli": "^18.7.0",
    "expo-doctor": "~1.18.18",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "typescript": "^5.5.3"
  }
}
